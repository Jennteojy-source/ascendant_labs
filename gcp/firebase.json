{
  "hosting": {
    "public": "../",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "gcp/**"
    ],
    "rewrites": [
      {
        "source": "/api/leads",
        "function": "submitLead"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  }
}
