{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/r/nordvpn",
        "function": "redirectNordVpn"
      },
      {
        "source": "/api/nordvpn-webhook",
        "function": "nordVpnWebhook"
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  }
}
